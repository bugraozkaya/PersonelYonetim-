@model IEnumerable<Personel>

@{
    ViewData["Title"] = "Personel Listesi";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Personel Listesi</h1>
    <a asp-action="Create" class="btn btn-primary">+ Yeni Personel Ekle</a>
</div>

@* Arama/filtre formu: method="get" oldugu icin secimler URL'ye yazilir
   (?arama=...&departman=...) ve Index action'inin parametrelerine baglanir *@
<form method="get" class="card card-body mb-3">
    <div class="row g-2 align-items-end">
        <div class="col-md-4">
            <label class="form-label">Ara (ad veya e-posta)</label>
            <input type="text" name="arama" value="@ViewData["Arama"]"
                   class="form-control" placeholder="örn. Ali" />
        </div>
        <div class="col-md-3">
            <label class="form-label">Departman</label>
            <select name="departman" class="form-select"
                    asp-items="@((SelectList)ViewData["Departmanlar"]!)">
                <option value="">Tümü</option>
            </select>
        </div>
        <div class="col-md-2">
            <div class="form-check">
                <input type="checkbox" name="sadeceAktif" value="true"
                       class="form-check-input" id="sadeceAktif"
                       checked="@((bool)ViewData["SadeceAktif"]! ? "checked" : null)" />
                <label class="form-check-label" for="sadeceAktif">Sadece aktifler</label>
            </div>
        </div>
        <div class="col-md-3">
            <button type="submit" class="btn btn-primary">Filtrele</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Temizle</a>
        </div>
    </div>
</form>

@* Hic kayit yoksa tablo yerine bilgi kutusu goster *@
@if (!Model.Any())
{
    <div class="alert alert-info">Bu kriterlere uyan personel bulunamadı.</div>
}
else
{
    <table class="table table-striped table-hover align-middle">
        <thead class="table-dark">
            <tr>
                <th>Ad Soyad</th>
                <th>Departman</th>
                <th>Pozisyon</th>
                <th>E-posta</th>
                <th class="text-end">Maaş</th>
                <th>İşe Giriş</th>
                <th>Durum</th>
                <th>İşlemler</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var p in Model)
        {
            <tr>
                <td>@p.AdSoyad</td>
                <td>@p.Departman</td>
                <td>@p.Pozisyon</td>
                <td>@p.Eposta</td>
                @* Maasi TL para formatinda goster *@
                <td class="text-end">@p.Maas.ToString("C2", new System.Globalization.CultureInfo("tr-TR"))</td>
                <td>@p.IseGirisTarihi.ToString("dd.MM.yyyy")</td>
                <td>
                    @if (p.AktifMi)
                    {
                        <span class="badge bg-success">Aktif</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">Pasif</span>
                    }
                </td>
                <td>
                    @* asp-route-id linke kaydin id'sini ekler: /Personeller/Edit/3 gibi *@
                    <a asp-action="Details" asp-route-id="@p.Id" class="btn btn-sm btn-outline-info">Detay</a>
                    <a asp-action="Edit" asp-route-id="@p.Id" class="btn btn-sm btn-outline-warning">Düzenle</a>
                    <a asp-action="Delete" asp-route-id="@p.Id" class="btn btn-sm btn-outline-danger">Sil</a>
                </td>
            </tr>
        }
        </tbody>
    </table>
}
