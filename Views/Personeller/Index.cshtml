@model IEnumerable<Personel>

@{
    ViewData["Title"] = "Personel Listesi";

    // ViewData'dan gelen degerleri bir kez degiskene alalim: asagisi temiz kalsin
    var arama = (string?)ViewData["Arama"];
    var secilenDepartman = (string?)ViewData["SecilenDepartman"];
    var sadeceAktif = (bool)ViewData["SadeceAktif"]!;
    var mevcutSirala = (string?)ViewData["MevcutSirala"];
    var sayfa = (int)ViewData["Sayfa"]!;
    var toplamSayfa = (int)ViewData["ToplamSayfa"]!;
    var toplamKayit = (int)ViewData["ToplamKayit"]!;

    // Checkbox isaretliyse route'a "true" yaz, degilse hic yazma
    var aktifParam = sadeceAktif ? "true" : null;

    // Aktif siralanan sutunun yanina yon oku koy
    string Ok(string asc) => mevcutSirala == asc ? " ▲"
                           : mevcutSirala == asc + "_desc" ? " ▼" : "";
    var adOk = string.IsNullOrEmpty(mevcutSirala) ? " ▲"
             : mevcutSirala == "ad_desc" ? " ▼" : "";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Personel Listesi</h1>
    <a asp-action="Create" class="btn btn-primary">+ Yeni Personel Ekle</a>
</div>

@* Arama/filtre formu: method="get" oldugu icin secimler URL'ye yazilir *@
<form method="get" class="card card-body mb-3">
    <div class="row g-2 align-items-end">
        <div class="col-md-4">
            <label class="form-label">Ara (ad veya e-posta)</label>
            <input type="text" name="arama" value="@arama"
                   class="form-control" placeholder="örn. Ali" />
        </div>
        <div class="col-md-3">
            <label class="form-label">Departman</label>
            <select name="departman" class="form-select"
                    asp-items="@((SelectList)ViewData["Departmanlar"]!)">
                <option value="">Tümü</option>
            </select>
        </div>
        <div class="col-md-2">
            <div class="form-check">
                <input type="checkbox" name="sadeceAktif" value="true"
                       class="form-check-input" id="sadeceAktif"
                       checked="@(sadeceAktif ? "checked" : null)" />
                <label class="form-check-label" for="sadeceAktif">Sadece aktifler</label>
            </div>
        </div>
        <div class="col-md-3">
            <button type="submit" class="btn btn-primary">Filtrele</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Temizle</a>
        </div>
    </div>
</form>

<p class="text-muted">@toplamKayit kayıt bulundu.</p>

@if (!Model.Any())
{
    <div class="alert alert-info">Bu kriterlere uyan personel bulunamadı.</div>
}
else
{
    <table class="table table-striped table-hover align-middle">
        <thead class="table-dark">
            <tr>
                @* Baslik linkleri: tiklaninca sirala parametresini degistirir.
                   Filtreler (arama, departman...) linke tasinir ki kaybolmasin;
                   sayfa=1'e doner cunku siralama degisince eski sayfa anlamsizdir *@
                <th>
                    <a class="text-white text-decoration-none" asp-action="Index"
                       asp-route-sirala="@ViewData["AdSirala"]" asp-route-arama="@arama"
                       asp-route-departman="@secilenDepartman" asp-route-sadeceAktif="@aktifParam">
                        Ad Soyad@(adOk)
                    </a>
                </th>
                <th>
                    <a class="text-white text-decoration-none" asp-action="Index"
                       asp-route-sirala="@ViewData["DepartmanSirala"]" asp-route-arama="@arama"
                       asp-route-departman="@secilenDepartman" asp-route-sadeceAktif="@aktifParam">
                        Departman@(Ok("departman"))
                    </a>
                </th>
                <th>Pozisyon</th>
                <th>E-posta</th>
                <th class="text-end">
                    <a class="text-white text-decoration-none" asp-action="Index"
                       asp-route-sirala="@ViewData["MaasSirala"]" asp-route-arama="@arama"
                       asp-route-departman="@secilenDepartman" asp-route-sadeceAktif="@aktifParam">
                        Maaş@(Ok("maas"))
                    </a>
                </th>
                <th>
                    <a class="text-white text-decoration-none" asp-action="Index"
                       asp-route-sirala="@ViewData["TarihSirala"]" asp-route-arama="@arama"
                       asp-route-departman="@secilenDepartman" asp-route-sadeceAktif="@aktifParam">
                        İşe Giriş@(Ok("tarih"))
                    </a>
                </th>
                <th>Durum</th>
                <th>İşlemler</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var p in Model)
        {
            <tr>
                <td>@p.AdSoyad</td>
                <td>@p.Departman</td>
                <td>@p.Pozisyon</td>
                <td>@p.Eposta</td>
                <td class="text-end">@p.Maas.ToString("C2", new System.Globalization.CultureInfo("tr-TR"))</td>
                <td>@p.IseGirisTarihi.ToString("dd.MM.yyyy")</td>
                <td>
                    @if (p.AktifMi)
                    {
                        <span class="badge bg-success">Aktif</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">Pasif</span>
                    }
                </td>
                <td>
                    <a asp-action="Details" asp-route-id="@p.Id" class="btn btn-sm btn-outline-info">Detay</a>
                    <a asp-action="Edit" asp-route-id="@p.Id" class="btn btn-sm btn-outline-warning">Düzenle</a>
                    <a asp-action="Delete" asp-route-id="@p.Id" class="btn btn-sm btn-outline-danger">Sil</a>
                </td>
            </tr>
        }
        </tbody>
    </table>

    @* Sayfalama cubugu: filtre + siralama korunur, sadece sayfa degisir *@
    @if (toplamSayfa > 1)
    {
        <nav aria-label="Sayfalar">
            <ul class="pagination">
                <li class="page-item @(sayfa == 1 ? "disabled" : "")">
                    <a class="page-link" asp-action="Index" asp-route-sayfa="@(sayfa - 1)"
                       asp-route-arama="@arama" asp-route-departman="@secilenDepartman"
                       asp-route-sadeceAktif="@aktifParam" asp-route-sirala="@mevcutSirala">
                        « Önceki
                    </a>
                </li>
                @for (var i = 1; i <= toplamSayfa; i++)
                {
                    <li class="page-item @(i == sayfa ? "active" : "")">
                        <a class="page-link" asp-action="Index" asp-route-sayfa="@i"
                           asp-route-arama="@arama" asp-route-departman="@secilenDepartman"
                           asp-route-sadeceAktif="@aktifParam" asp-route-sirala="@mevcutSirala">
                            @i
                        </a>
                    </li>
                }
                <li class="page-item @(sayfa == toplamSayfa ? "disabled" : "")">
                    <a class="page-link" asp-action="Index" asp-route-sayfa="@(sayfa + 1)"
                       asp-route-arama="@arama" asp-route-departman="@secilenDepartman"
                       asp-route-sadeceAktif="@aktifParam" asp-route-sirala="@mevcutSirala">
                        Sonraki »
                    </a>
                </li>
            </ul>
        </nav>
    }
}
