@model Personel

@{
    ViewData["Title"] = "Personel Düzenle";
}

<h1>Personel Düzenle</h1>
<hr />

<div class="row">
    <div class="col-md-6">
        <form asp-action="Edit" method="post" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            @* Id ve mevcut fotograf yolu gizli tasinir: kullanici gormez ama POST'ta gider *@
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="FotografYolu" />

            <div class="mb-3">
                <label asp-for="AdSoyad" class="form-label"></label>
                <input asp-for="AdSoyad" class="form-control" />
                <span asp-validation-for="AdSoyad" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="DepartmanId" class="form-label"></label>
                <select asp-for="DepartmanId" class="form-select"
                        asp-items="@((SelectList)ViewData["DepartmanListesi"]!)">
                    <option value="">-- Departman Seçiniz --</option>
                </select>
                <span asp-validation-for="DepartmanId" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Pozisyon" class="form-label"></label>
                <input asp-for="Pozisyon" class="form-control" />
                <span asp-validation-for="Pozisyon" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Eposta" class="form-label"></label>
                <input asp-for="Eposta" class="form-control" />
                <span asp-validation-for="Eposta" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Maas" class="form-label"></label>
                <input asp-for="Maas" class="form-control" />
                <span asp-validation-for="Maas" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="IseGirisTarihi" class="form-label"></label>
                <input asp-for="IseGirisTarihi" class="form-control" />
                <span asp-validation-for="IseGirisTarihi" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label class="form-label">Fotoğraf</label>
                @if (!string.IsNullOrEmpty(Model.FotografYolu))
                {
                    <div class="mb-2">
                        <img src="@Model.FotografYolu" alt="@Model.AdSoyad" class="rounded"
                             style="width: 80px; height: 80px; object-fit: cover;" />
                        <small class="text-muted d-block">Yeni dosya seçersen mevcut fotoğraf değişir.</small>
                    </div>
                }
                <input type="file" name="fotograf" class="form-control" accept=".jpg,.jpeg,.png" />
                <span asp-validation-for="FotografYolu" class="text-danger"></span>
            </div>

            <div class="form-check mb-3">
                <input asp-for="AktifMi" class="form-check-input" />
                <label asp-for="AktifMi" class="form-check-label"></label>
            </div>

            <button type="submit" class="btn btn-warning">Güncelle</button>
            <a asp-action="Index" class="btn btn-secondary">İptal</a>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
